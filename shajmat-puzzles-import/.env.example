# Copiá este archivo a .env y pegá tus credenciales de Supabase
# ⚠ NO subas el .env a Git — contiene la service_role key

# Supabase → tu proyecto → Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Supabase → tu proyecto → Settings → API → Project API Keys → service_role (secret)
# (la que dice "secret", NO la "anon public")
SUPABASE_SERVICE_KEY=eyJhbGci...
